# Copy this file to .env.local and fill in real values. .env.local is
# gitignored — never commit real secrets.

# --- Resend (https://resend.com) ---------------------------------------
# API key from https://resend.com/api-keys. Needs at least "Sending access".
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sender address for the auto-reply. Until you verify a domain in Resend
# (https://resend.com/domains), you can only send from Resend's shared test
# address, and only to the email you signed up to Resend with:
RESEND_FROM_EMAIL=Mukago <onboarding@resend.dev>
# Once mukago.co.uk is verified in Resend, switch this to something like:
# Mukago <hello@mukago.co.uk>

# Audience to add new signups to — create one at
# https://resend.com/audiences, then paste its ID here.
RESEND_AUDIENCE_ID=00000000-0000-0000-0000-000000000000

# Where the "someone new signed up" admin notification gets sent.
ADMIN_EMAIL=ibrahim@mukago.co.uk

# --- Supabase (https://supabase.com) ------------------------------------
# For local development, run `supabase start` and use the values it prints
# (API URL and `service_role` key). For production, use your hosted
# project's Settings -> API page.
SUPABASE_URL=http://127.0.0.1:54421
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# --- Upstash Redis (https://console.upstash.com) ------------------------
# Free tier is plenty. Create a Redis database, then copy the REST URL/token
# from its dashboard. Required in production — the app refuses to boot
# without these when NODE_ENV=production, so signups can't go unthrottled.
UPSTASH_REDIS_REST_URL=https://xxxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Misc -----------------------------------------------------------------
# Public site URL, used for metadata/Open Graph tags. Safe to expose to the
# browser (hence NEXT_PUBLIC_ prefix) — not a secret.
NEXT_PUBLIC_SITE_URL=https://mukago.co.uk
